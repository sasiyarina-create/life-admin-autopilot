generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Tracked personal administration record. Authentication is intentionally omitted
/// for the single-user MVP; add a userId relation when multi-user support is added.
model Item {
  id            String   @id @default(cuid())
  type          String   @default("OTHER")
  vendorName    String
  amount        Float?
  currency      String?
  renewalDate   DateTime?
  cancelByDate  DateTime?
  status        String   @default("NEEDS_REVIEW")
  sourceType    String   @default("MANUAL")
  sourceRawText String?
  confidence    Float?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([renewalDate])
  @@index([cancelByDate])
}

model GmailConnection {
  id           String   @id @default("default")
  email        String
  refreshToken String
  lastSyncAt   DateTime?
  importedCount Int      @default(0)
  lastScanned  Int      @default(0)
  lastRelevant Int      @default(0)
  lastDuplicates Int    @default(0)
  lastIgnored  Int      @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model GmailImport {
  id             String   @id @default(cuid())
  gmailMessageId String   @unique
  threadId       String?
  sender         String?
  subject        String?
  receivedAt     DateTime?
  itemId         String?
  createdAt      DateTime @default(now())
}

model PendingImport {
  id                  String   @id @default(cuid())
  gmailMessageId      String   @unique
  sender              String?
  subject             String?
  preview             String
  vendor              String
  type                String
  amount              Float?
  currency            String?
  renewalDate         DateTime?
  cancelByDate        DateTime?
  confidence          Float
  confidenceReasons   String
  notes               String?
  status              String   @default("PENDING")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([confidence])
}

/// SQLite does not support Prisma database enums. Application code will validate
/// these string values: ItemType = SUBSCRIPTION | BILL | WARRANTY | APPOINTMENT | OTHER
/// ItemStatus = ACTIVE | CANCELLED | EXPIRED | NEEDS_REVIEW
/// SourceType = EMAIL | PHOTO | MANUAL
